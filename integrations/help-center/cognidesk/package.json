{
  "name": "@cognidesk/integration-help-center-cognidesk",
  "version": "0.0.3",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts src/integration.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "workspace:*",
    "@cognidesk/integration-kit": "workspace:*"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "cognidesk": {
    "providerPackage": true,
    "release": "independent-provider",
    "providerSdkDependencies": [],
    "providerSdkDecision": {
      "checkedAt": "2026-06-25",
      "result": "not-applicable-internal-provider",
      "reason": "Cognidesk Help Center is an internal local/HTTP-source protocol and host-client adapter; it does not wrap a named external help-center provider SDK.",
      "defaultClientPolicy": "built-in-http-source-when-base-url-configured",
      "typedClientOverride": "HelpCenterProviderClient",
      "rejectedSdkPackages": []
    },
    "manifestOnlyExports": [
      "./manifest"
    ],
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 1048576,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/help-center/cognidesk"
  }
}
