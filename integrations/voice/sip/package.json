{
  "name": "@cognidesk/integration-voice-sip",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts src/integration.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "workspace:*",
    "@cognidesk/integration-kit": "workspace:*",
    "drachtio-srf": "^5.0.24"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "cognidesk": {
    "providerPackage": true,
    "release": "independent-provider",
    "manifestOnlyExports": [
      "./manifest"
    ],
    "providerSdkDependencies": [
      "drachtio-srf"
    ],
    "providerSdkDecision": {
      "checkedAt": "2026-06-25",
      "result": "runtime-protocol-lib-selected",
      "selectedSdkPackage": "drachtio-srf",
      "reason": "drachtio-srf is a maintained, typed, server-side SIP signaling resource framework suitable for this package's outbound UAC and dialog-level call-control gateway operations.",
      "defaultClientPolicy": "drachtio-srf-gateway-when-configured-or-host-injected-SipStackGateway",
      "typedClientOverride": "SipStackGateway",
      "rejectedSdkPackages": [
        {
          "packageName": "sip.js",
          "ecosystem": "npm",
          "reason": "Typed SIP library, but the current package surface needs server-side SIP gateway/dialog control rather than a browser/WebRTC User-Agent-first stack."
        },
        {
          "packageName": "jssip",
          "ecosystem": "npm",
          "reason": "Typed and maintained SIP library, but its browser/User-Agent-oriented runtime surface is not the best fit for server-side BYOC SIP gateway operations."
        }
      ]
    },
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 1048576,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/voice/sip"
  }
}
