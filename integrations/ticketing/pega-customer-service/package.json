{
  "name": "@cognidesk/integration-ticketing-pega-customer-service",
  "version": "0.0.5",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "0.0.11",
    "@cognidesk/integration-kit": "0.0.11"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "0.0.11",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "cognidesk": {
    "kind": "provider-package",
    "providerPackage": true,
    "release": "independent-provider",
    "category": "ticketing",
    "provider": "pega-customer-service",
    "manifestOnlyExports": [
      "./manifest"
    ],
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 2097152,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    },
    "providerRestAdapterException": {
      "checkedAt": "2026-06-25",
      "result": "no-official-dx-case-runtime-sdk",
      "reason": "Pega-maintained JavaScript packages verified on npm cover OAuth and Constellation UI/runtime assets, not the server-side DX case, case type, assignment action, and readiness operations exposed by this package.",
      "defaultClientPolicy": "built-in-pega-dx-rest-adapter",
      "typedClientOverride": "PegaCustomerServiceProviderClient",
      "rejectedSdkPackages": [
        {
          "packageName": "@pega/auth",
          "checkedVersion": "0.2.41",
          "license": "Apache-2.0",
          "reason": "Official Pega OAuth client library for Infinity and Launchpad, but not a typed Customer Service/DX case operations client."
        },
        {
          "packageName": "@pega/constellationjs",
          "checkedVersion": "25.1.3",
          "license": "See LICENSE in LICENSE file or 'ConstellationJS Engine License.pdf' in dist/",
          "reason": "Official Pega ConstellationJS engine package, not a server-side DX case/ticketing runtime client."
        },
        {
          "packageName": "@pega/react-sdk-components",
          "checkedVersion": "25.1.11",
          "license": "SEE LICENCE IN LICENSE",
          "reason": "Official Pega React SDK infrastructure for UI bridge/components, not backend ticketing provider operations."
        }
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/ticketing/pega-customer-service"
  }
}
