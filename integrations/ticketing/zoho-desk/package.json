{
  "name": "@cognidesk/integration-ticketing-zoho-desk",
  "version": "0.0.6",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "0.0.12",
    "@cognidesk/integration-kit": "0.0.12"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "0.0.12",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "cognidesk": {
    "kind": "provider-package",
    "providerPackage": true,
    "release": "independent-provider",
    "category": "ticketing",
    "provider": "zoho-desk",
    "providerRestAdapterException": {
      "checkedAt": "2026-06-25",
      "result": "no-official-maintained-zoho-desk-node-runtime-sdk",
      "reason": "No maintained official Zoho Desk Node/TypeScript backend ticketing SDK was verified. Zoho-official npm packages found target CRM, Catalyst, SalesIQ, Desk UI/extension/client packages, or generic API building, while the direct zoho-desk-sdk package is third-party and stale.",
      "defaultClientPolicy": "built-in-zoho-desk-rest-adapter",
      "typedClientOverride": "ZohoDeskProviderClient",
      "rejectedSdkPackages": [
        {
          "packageName": "zoho-desk-sdk",
          "checkedVersion": "0.1.7",
          "license": "MIT",
          "reason": "Third-party Node SDK for Zoho Desk, not Zoho-maintained and last published years ago."
        },
        {
          "packageName": "@zohodesk/client_packages_group",
          "checkedVersion": "1.0.3",
          "license": "ISC",
          "reason": "Zoho Desk client package group/UI surface, not a server-side ticketing REST runtime SDK."
        },
        {
          "packageName": "@zohodesk/js-api-creator",
          "checkedVersion": "1.0.25",
          "license": "MIT",
          "reason": "Generic API-call builder, not a dedicated typed Zoho Desk ticketing provider client."
        },
        {
          "packageName": "@zohocrm/typescript-sdk-8.0",
          "checkedVersion": "3.0.0",
          "license": "Apache-2.0",
          "reason": "Zoho-maintained CRM SDK, not Zoho Desk ticketing."
        }
      ]
    },
    "manifestOnlyExports": [
      "./manifest"
    ],
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 2097152,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/ticketing/zoho-desk"
  }
}
