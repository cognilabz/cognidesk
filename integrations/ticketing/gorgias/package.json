{
  "name": "@cognidesk/integration-ticketing-gorgias",
  "version": "0.0.5",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "0.0.11",
    "@cognidesk/integration-kit": "0.0.11"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "cognidesk": {
    "kind": "provider-package",
    "providerPackage": true,
    "release": "independent-provider",
    "category": "ticketing",
    "provider": "gorgias",
    "manifestOnlyExports": [
      "./manifest"
    ],
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 2097152,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    },
    "providerRestAdapterException": {
      "checkedAt": "2026-06-25",
      "result": "no-official-maintained-ticketing-runtime-sdk",
      "reason": "No Gorgias-maintained JavaScript/TypeScript backend ticketing SDK was verified. The available npm clients are third-party, framework, frontend, MCP, or automation component packages rather than a provider-owned runtime SDK for the ticket, message, account-readiness, and raw request operations exposed by this package.",
      "defaultClientPolicy": "built-in-gorgias-rest-adapter",
      "typedClientOverride": "GorgiasTicketingProviderClient",
      "rejectedSdkPackages": [
        {
          "packageName": "gorgias-client",
          "checkedVersion": "2.0.4",
          "license": "MIT",
          "reason": "Typed and recent, but maintained outside Gorgias; not a provider-owned SDK dependency for this package default runtime."
        },
        {
          "packageName": "@friggframework/api-module-gorgias",
          "checkedVersion": "0.10.1",
          "license": "MIT",
          "reason": "Frigg framework API module, not a standalone official Gorgias backend SDK for this runtime package."
        },
        {
          "packageName": "@frontend-sdk/gorgias",
          "checkedVersion": "0.26.0",
          "license": "MIT",
          "reason": "Frontend integration package, not a maintained backend ticketing runtime SDK."
        },
        {
          "packageName": "@pipedream/gorgias",
          "checkedVersion": "0.6.0",
          "license": "not-declared",
          "reason": "Pipedream component package rather than a typed provider runtime SDK suitable as this package's default."
        }
      ]
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/ticketing/gorgias"
  }
}
