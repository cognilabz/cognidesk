{
  "name": "@cognidesk/integration-ticketing-freshdesk",
  "version": "0.0.4",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@freshworks/freshdesk": "^0.0.1",
    "@cognidesk/core": "workspace:*",
    "@cognidesk/integration-kit": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "cognidesk": {
    "kind": "provider-package",
    "providerPackage": true,
    "release": "independent-provider",
    "category": "ticketing",
    "provider": "freshdesk",
    "providerSdkRuntime": {
      "sdkPackage": "@freshworks/freshdesk",
      "checkedAt": "2026-06-25",
      "checkedVersion": "0.0.1",
      "license": "freshdesk",
      "result": "accepted-default-runtime-sdk",
      "reason": "@freshworks/freshdesk is the official Freshdesk JavaScript SDK package and exposes tickets, contacts, and conversations runtime clients used by this package.",
      "defaultClientPolicy": "official-sdk-for-covered-operations-with-host-provider-client-required-for-sdk-gaps",
      "typedClientOverride": "FreshdeskTicketingProviderClient"
    },
    "manifestOnlyExports": [
      "./manifest"
    ],
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 2097152,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/ticketing/freshdesk"
  }
}
