{
  "name": "@cognidesk/integration-ticketing-oracle-service",
  "version": "0.0.4",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "workspace:*",
    "@cognidesk/integration-kit": "workspace:*"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "cognidesk": {
    "kind": "provider-package",
    "providerPackage": true,
    "release": "independent-provider",
    "category": "ticketing",
    "provider": "oracle-service",
    "manifestOnlyExports": [
      "./manifest"
    ],
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 2097152,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    },
    "providerRestAdapterException": {
      "checkedAt": "2026-06-25",
      "result": "no-oracle-fusion-service-ticketing-runtime-sdk",
      "reason": "Oracle-maintained JavaScript SDK packages verified on npm target OCI/Fusion Apps administration or database/client infrastructure, not the Oracle Fusion Service serviceRequests and child message REST resources exposed by this support package. The only Oracle Service Cloud wrapper found is unofficial and stale.",
      "defaultClientPolicy": "built-in-oracle-fusion-service-rest-adapter",
      "typedClientOverride": "OracleServiceTicketingProviderClient",
      "rejectedSdkPackages": [
        {
          "packageName": "oci-fusionapps",
          "checkedVersion": "2.135.1",
          "license": "(UPL-1.0 OR Apache-2.0)",
          "reason": "Oracle-maintained OCI Fusion Apps Service administration SDK, not a typed Oracle Fusion Service serviceRequests ticketing data client."
        },
        {
          "packageName": "oci-sdk",
          "checkedVersion": "2.135.1",
          "license": "(UPL-1.0 OR Apache-2.0)",
          "reason": "Oracle-maintained OCI aggregate SDK; does not expose the Oracle Fusion Service serviceRequests or Oracle B2C Service incident runtime surface used here."
        },
        {
          "packageName": "osvc_node",
          "checkedVersion": "1.0.0",
          "license": "MIT",
          "reason": "Unofficial Oracle Service Cloud REST wrapper, not a maintained Oracle-owned runtime SDK suitable as this package's default."
        }
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/ticketing/oracle-service"
  }
}
