{
  "name": "@cognidesk/integration-community-forum",
  "version": "0.0.5",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts src/integration.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "0.0.11",
    "@cognidesk/integration-kit": "0.0.11"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "0.0.11",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "cognidesk": {
    "providerPackage": true,
    "release": "independent-provider",
    "providerRestAdapterException": {
      "checkedAt": "2026-06-25",
      "result": "no-applicable-official-js-ts-sdk",
      "reason": "Discourse documentation recommends the official discourse_api Ruby gem for Ruby consumers, but no applicable official JavaScript or TypeScript Discourse provider SDK was verified for this package's server-side support workflow surface.",
      "defaultClientPolicy": "built-in-discourse-rest-adapter-when-configured",
      "typedClientOverride": "ForumCommunityProviderClient",
      "rejectedSdkPackages": [
        {
          "packageName": "discourse_api",
          "ecosystem": "ruby",
          "reason": "Officially documented Ruby client library; not a JavaScript or TypeScript runtime SDK."
        },
        {
          "packageName": "discourse-api-sdk",
          "ecosystem": "npm",
          "reason": "Third-party npm publisher and repository; not published by the Discourse npm organization, despite package description text."
        },
        {
          "packageName": "@discourse/mcp",
          "ecosystem": "npm",
          "reason": "Official Discourse MCP CLI server, not an in-process JavaScript or TypeScript provider API client for this runtime package."
        },
        {
          "packageName": "discourse-sdk",
          "ecosystem": "npm",
          "reason": "Unofficial, old, and untyped npm package surface; unsuitable as the strict provider SDK dependency for this package."
        }
      ]
    },
    "manifestOnlyExports": [
      "./manifest"
    ],
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 1048576,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/community/forum"
  }
}
