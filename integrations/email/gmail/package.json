{
  "name": "@cognidesk/integration-email-gmail",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --filter @cognidesk/core --filter @cognidesk/integration-kit --filter @cognidesk/test-harness build",
    "build": "pnpm run build:deps && tsup src/index.ts src/manifest.ts --format esm --dts --sourcemap",
    "typecheck": "pnpm run build:deps && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/integration-kit": "workspace:*",
    "@googleapis/gmail": "^17.0.0"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "cognidesk": {
    "kind": "provider-package",
    "providerPackage": true,
    "release": "independent-provider",
    "manifestOnlyExports": [
      "./manifest"
    ],
    "providerSdkDependencies": [
      "@googleapis/gmail"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/email/gmail"
  }
}
