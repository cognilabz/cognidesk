{
  "name": "@cognidesk/integration-marketplace-amazon",
  "version": "0.0.3",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./cognidesk": {
      "types": "./dist/cognidesk.d.ts",
      "import": "./dist/cognidesk.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts src/cognidesk.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@amazon-sp-api-release/amazon-sp-api-sdk-js": "^1.9.0",
    "@cognidesk/integration-kit": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/marketplace/amazon"
  },
  "cognidesk": {
    "providerPackage": true,
    "kind": "provider-package",
    "release": "independent-provider",
    "manifestOnlyExports": [
      "./manifest",
      "./cognidesk"
    ],
    "providerSdkDependencies": [
      "@amazon-sp-api-release/amazon-sp-api-sdk-js"
    ],
    "sizeBudget": {
      "dist": "2 MiB",
      "declarationChunk": "1 MiB"
    },
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 2097152,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    }
  }
}
