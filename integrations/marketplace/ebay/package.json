{
  "name": "@cognidesk/integration-marketplace-ebay",
  "version": "0.0.5",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/manifest.ts src/runtime.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/integration-kit": "0.0.11",
    "digital-signature-nodejs-sdk": "^3.0.1",
    "event-notification-nodejs-sdk": "^1.0.3"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "integrations/marketplace/ebay"
  },
  "cognidesk": {
    "providerPackage": true,
    "kind": "provider-package",
    "release": "independent-provider",
    "manifestOnlyExports": [
      "./manifest"
    ],
    "sizeBudget": {
      "dist": "2 MiB",
      "declarationChunk": "1 MiB"
    },
    "packageSizeBudgetBytes": {
      "packedSizeBytes": 2097152,
      "unpackedSizeBytes": 4194304,
      "declarationFileBytes": 1048576
    },
    "providerRestAdapterException": {
      "checkedAt": "2026-06-25",
      "result": "no-provider-owned-general-ebay-rest-sdk",
      "packagesRejected": [
        {
          "package": "ebay-api",
          "checkedVersion": "9.5.2",
          "license": "MIT",
          "reason": "Community-maintained typed wrapper, not eBay/provider-owned."
        },
        {
          "package": "@tradebuddyhq/ebay-wrapper",
          "checkedVersion": "2.0.0",
          "license": "MIT",
          "reason": "Community-maintained typed wrapper, not eBay/provider-owned."
        },
        {
          "package": "ebay-oauth-nodejs-client",
          "checkedVersion": "1.2.2",
          "license": "ISC",
          "reason": "Provider-owned OAuth helper only; it does not expose the selected Sell Fulfillment, Commerce Message, Commerce Notification, Developer Key Management, or Commerce Identity operations."
        }
      ],
      "defaultClientPolicy": "built-in-ebay-rest-adapter-for-selected-rest-operations",
      "typedClientOverride": "EbayMarketplaceProviderClient"
    }
  }
}
