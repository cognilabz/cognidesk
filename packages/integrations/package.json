{
  "name": "@cognidesk/integrations",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --filter @cognidesk/core --filter @cognidesk/voice-websocket --filter @cognidesk/test-harness build",
    "build": "pnpm run build:deps && tsup src/index.ts --format esm --dts --clean",
    "typecheck": "pnpm run build:deps && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run",
    "lint": "pnpm run build:deps && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "workspace:*"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "workspace:*",
    "@cognidesk/voice-websocket": "workspace:*",
    "openai": "^6.42.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "packages/integrations"
  }
}
