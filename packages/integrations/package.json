  "scripts": {
    "build:deps": "pnpm --filter @cognidesk/core --filter @cognidesk/integration-kit --filter @cognidesk/voice-websocket --filter @cognidesk/test-harness build",
    "build": "pnpm run build:deps && pnpm run build:entries:voice && pnpm run build:entries:contact-center-a && pnpm run build:entries:contact-center-b && pnpm run build:entries:community && pnpm run build:entries:marketplace && pnpm run build:entries:form-help-center && pnpm run build:entries:sms && pnpm run build:entries:video && pnpm run build:entries:ticketing-a && pnpm run build:entries:ticketing-b && pnpm run build:entries:ticketing-c",
    "build:entries:voice": "tsup src/index.ts src/category-profiles.ts src/provider-manifest.ts src/voice/aws-speech/index.ts src/voice/azure-speech/index.ts src/voice/deepgram/index.ts src/voice/elevenlabs/index.ts src/voice/google-speech/index.ts src/voice/openai/index.ts src/voice/sip/index.ts src/voice/twilio/index.ts src/voice/vonage/index.ts --format esm --dts --clean --external openai",
    "build:entries:contact-center-a": "tsup src/contact-center/8x8/index.ts src/contact-center/aircall/index.ts src/contact-center/amazon-connect/index.ts src/contact-center/five9/index.ts src/contact-center/genesys-cloud/index.ts src/contact-center/genesys-engage/index.ts --format esm --dts --outDir dist/contact-center --external openai",
    "build:entries:contact-center-b": "tsup src/contact-center/genesys-pureconnect/index.ts src/contact-center/nextiva/index.ts src/contact-center/nice-cxone/index.ts src/contact-center/ringcentral/index.ts src/contact-center/talkdesk/index.ts src/contact-center/zoom/index.ts --format esm --dts --outDir dist/contact-center --external openai",
    "build:entries:community": "tsup src/cobrowsing/cognidesk/index.ts src/community/forum/index.ts --format esm --dts --external openai",
    "build:entries:marketplace": "tsup src/marketplace/amazon/index.ts src/marketplace/ebay/index.ts --format esm --dts --outDir dist/marketplace --external openai",
    "build:entries:form-help-center": "tsup src/form/cognidesk/index.ts src/help-center/cognidesk/index.ts --format esm --dts --external openai",
    "build:entries:sms": "tsup src/sms/twilio/index.ts --format esm --dts --outDir dist/sms/twilio --external openai",
    "build:entries:video": "tsup src/video/whereby/index.ts src/video/zoom/index.ts --format esm --dts --outDir dist/video --external openai",
    "build:entries:ticketing-a": "tsup src/ticketing/dynamics365/index.ts --format esm --dts --outDir dist/ticketing/dynamics365 --external openai",
    "build:entries:ticketing-b": "tsup src/ticketing/hubspot/index.ts src/ticketing/intercom/index.ts src/ticketing/oracle-service/index.ts src/ticketing/pega-customer-service/index.ts --format esm --dts --outDir dist/ticketing --external openai",
    "build:entries:ticketing-c": "tsup src/ticketing/salesforce/index.ts src/ticketing/sap-service-cloud/index.ts src/ticketing/servicenow/index.ts src/ticketing/zoho-desk/index.ts --format esm --dts --outDir dist/ticketing --external openai",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "workspace:*",
    "@cognidesk/integration-kit": "workspace:*",
    "@cognidesk/voice-websocket": "workspace:*",
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "packages/integrations"
  }
}
