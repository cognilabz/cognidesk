{
  "name": "@cognidesk/integrations",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./category-profiles": {
      "types": "./dist/category-profiles.d.ts",
      "import": "./dist/category-profiles.js"
    },
    "./provider-manifest": {
      "types": "./dist/provider-manifest.d.ts",
      "import": "./dist/provider-manifest.js"
    },
    "./cobrowsing/cognidesk": {
      "types": "./dist/cobrowsing/cognidesk/index.d.ts",
      "import": "./dist/cobrowsing/cognidesk/index.js"
    },
    "./community/forum": {
      "types": "./dist/community/forum/index.d.ts",
      "import": "./dist/community/forum/index.js"
    },
    "./form/cognidesk": {
      "types": "./dist/form/cognidesk/index.d.ts",
      "import": "./dist/form/cognidesk/index.js"
    },
    "./help-center/cognidesk": {
      "types": "./dist/help-center/cognidesk/index.d.ts",
      "import": "./dist/help-center/cognidesk/index.js"
    },
    "./marketplace/amazon": {
      "types": "./dist/marketplace/amazon/index.d.ts",
      "import": "./dist/marketplace/amazon/index.js"
    },
    "./marketplace/ebay": {
      "types": "./dist/marketplace/ebay/index.d.ts",
      "import": "./dist/marketplace/ebay/index.js"
    },
    "./video/whereby": {
      "types": "./dist/video/whereby/index.d.ts",
      "import": "./dist/video/whereby/index.js"
    },
    "./video/zoom": {
      "types": "./dist/video/zoom/index.d.ts",
      "import": "./dist/video/zoom/index.js"
    },
    "./voice/aws-speech": {
      "types": "./dist/voice/aws-speech/index.d.ts",
      "import": "./dist/voice/aws-speech/index.js"
    },
    "./voice/azure-speech": {
      "types": "./dist/voice/azure-speech/index.d.ts",
      "import": "./dist/voice/azure-speech/index.js"
    },
    "./voice/google-speech": {
      "types": "./dist/voice/google-speech/index.d.ts",
      "import": "./dist/voice/google-speech/index.js"
    },
    "./voice/openai": {
      "types": "./dist/voice/openai/index.d.ts",
      "import": "./dist/voice/openai/index.js"
    },
    "./voice/sip": {
      "types": "./dist/voice/sip/index.d.ts",
      "import": "./dist/voice/sip/index.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --filter @cognidesk/core --filter @cognidesk/integration-kit --filter @cognidesk/voice-websocket --filter @cognidesk/test-harness build",
    "build": "pnpm run build:deps && pnpm run build:entries:voice && pnpm run build:entries:community && pnpm run build:entries:marketplace && pnpm run build:entries:form-help-center && pnpm run build:entries:video",
    "build:entries:voice": "tsup src/index.ts src/category-profiles.ts src/provider-manifest.ts src/voice/aws-speech/index.ts src/voice/azure-speech/index.ts src/voice/google-speech/index.ts src/voice/openai/index.ts src/voice/sip/index.ts --format esm --dts --clean --external openai",
    "build:entries:community": "tsup src/cobrowsing/cognidesk/index.ts src/community/forum/index.ts --format esm --dts --external openai",
    "build:entries:marketplace": "tsup src/marketplace/amazon/index.ts src/marketplace/ebay/index.ts --format esm --dts --outDir dist/marketplace --external openai",
    "build:entries:form-help-center": "tsup src/form/cognidesk/index.ts src/help-center/cognidesk/index.ts --format esm --dts --external openai",
    "build:entries:video": "tsup src/video/whereby/index.ts src/video/zoom/index.ts --format esm --dts --outDir dist/video --external openai",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "workspace:*",
    "@cognidesk/integration-kit": "workspace:*",
    "@cognidesk/voice-websocket": "workspace:*",
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "packages/integrations"
  }
}
