{
  "name": "@cognidesk/integrations",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contact-center/8x8": {
      "types": "./dist/contact-center/8x8/index.d.ts",
      "import": "./dist/contact-center/8x8/index.js"
    },
    "./contact-center/aircall": {
      "types": "./dist/contact-center/aircall/index.d.ts",
      "import": "./dist/contact-center/aircall/index.js"
    },
    "./contact-center/amazon-connect": {
      "types": "./dist/contact-center/amazon-connect/index.d.ts",
      "import": "./dist/contact-center/amazon-connect/index.js"
    },
    "./contact-center/five9": {
      "types": "./dist/contact-center/five9/index.d.ts",
      "import": "./dist/contact-center/five9/index.js"
    },
    "./contact-center/genesys-cloud": {
      "types": "./dist/contact-center/genesys-cloud/index.d.ts",
      "import": "./dist/contact-center/genesys-cloud/index.js"
    },
    "./contact-center/genesys-engage": {
      "types": "./dist/contact-center/genesys-engage/index.d.ts",
      "import": "./dist/contact-center/genesys-engage/index.js"
    },
    "./contact-center/genesys-pureconnect": {
      "types": "./dist/contact-center/genesys-pureconnect/index.d.ts",
      "import": "./dist/contact-center/genesys-pureconnect/index.js"
    },
    "./contact-center/nextiva": {
      "types": "./dist/contact-center/nextiva/index.d.ts",
      "import": "./dist/contact-center/nextiva/index.js"
    },
    "./contact-center/nice-cxone": {
      "types": "./dist/contact-center/nice-cxone/index.d.ts",
      "import": "./dist/contact-center/nice-cxone/index.js"
    },
    "./contact-center/ringcentral": {
      "types": "./dist/contact-center/ringcentral/index.d.ts",
      "import": "./dist/contact-center/ringcentral/index.js"
    },
    "./contact-center/talkdesk": {
      "types": "./dist/contact-center/talkdesk/index.d.ts",
      "import": "./dist/contact-center/talkdesk/index.js"
    },
    "./contact-center/zoom": {
      "types": "./dist/contact-center/zoom/index.d.ts",
      "import": "./dist/contact-center/zoom/index.js"
    },
    "./video/whereby": {
      "types": "./dist/video/whereby/index.d.ts",
      "import": "./dist/video/whereby/index.js"
    },
    "./video/zoom": {
      "types": "./dist/video/zoom/index.d.ts",
      "import": "./dist/video/zoom/index.js"
    },
    "./voice/aws-speech": {
      "types": "./dist/voice/aws-speech/index.d.ts",
      "import": "./dist/voice/aws-speech/index.js"
    },
    "./voice/azure-speech": {
      "types": "./dist/voice/azure-speech/index.d.ts",
      "import": "./dist/voice/azure-speech/index.js"
    },
    "./voice/deepgram": {
      "types": "./dist/voice/deepgram/index.d.ts",
      "import": "./dist/voice/deepgram/index.js"
    },
    "./voice/elevenlabs": {
      "types": "./dist/voice/elevenlabs/index.d.ts",
      "import": "./dist/voice/elevenlabs/index.js"
    },
    "./voice/google-speech": {
      "types": "./dist/voice/google-speech/index.d.ts",
      "import": "./dist/voice/google-speech/index.js"
    },
    "./voice/openai": {
      "types": "./dist/voice/openai/index.d.ts",
      "import": "./dist/voice/openai/index.js"
    },
    "./voice/sip": {
      "types": "./dist/voice/sip/index.d.ts",
      "import": "./dist/voice/sip/index.js"
    },
    "./voice/twilio": {
      "types": "./dist/voice/twilio/index.d.ts",
      "import": "./dist/voice/twilio/index.js"
    },
    "./voice/vonage": {
      "types": "./dist/voice/vonage/index.d.ts",
      "import": "./dist/voice/vonage/index.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --filter @cognidesk/core --filter @cognidesk/voice-websocket --filter @cognidesk/test-harness build",
    "build": "pnpm run build:deps && pnpm run build:entries:voice && pnpm run build:entries:contact-center-a && pnpm run build:entries:contact-center-b && pnpm run build:entries:video",
    "build:entries:voice": "tsup src/index.ts src/voice/aws-speech/index.ts src/voice/azure-speech/index.ts src/voice/deepgram/index.ts src/voice/elevenlabs/index.ts src/voice/google-speech/index.ts src/voice/openai/index.ts src/voice/sip/index.ts src/voice/twilio/index.ts src/voice/vonage/index.ts --format esm --dts --clean --external openai",
    "build:entries:contact-center-a": "tsup src/contact-center/8x8/index.ts src/contact-center/aircall/index.ts src/contact-center/amazon-connect/index.ts src/contact-center/five9/index.ts src/contact-center/genesys-cloud/index.ts src/contact-center/genesys-engage/index.ts --format esm --dts --outDir dist/contact-center --external openai",
    "build:entries:contact-center-b": "tsup src/contact-center/genesys-pureconnect/index.ts src/contact-center/nextiva/index.ts src/contact-center/nice-cxone/index.ts src/contact-center/ringcentral/index.ts src/contact-center/talkdesk/index.ts src/contact-center/zoom/index.ts --format esm --dts --outDir dist/contact-center --external openai",
    "build:entries:video": "tsup src/video/whereby/index.ts src/video/zoom/index.ts --format esm --dts --outDir dist/video --external openai",
    "typecheck": "pnpm run build:deps && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run",
    "lint": "pnpm run build:deps && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cognidesk/core": "workspace:*",
    "@cognidesk/voice-websocket": "workspace:*",
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "@cognidesk/test-harness": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cognilabz/cognidesk",
    "directory": "packages/integrations"
  }
}
