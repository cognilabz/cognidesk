{
  "models": {
    "provider": "openrouter",
    "apiKeyEnv": "OPENROUTER_KEY",
    "appName": "Cognidesk Flight Demo",
    "roles": {
      "response": "openai/gpt-5.4-mini",
      "compaction": "openai/gpt-5.4-mini",
      "matcher": "openai/gpt-5.4-mini",
      "extraction": "openai/gpt-5.4-mini",
      "citationPostProcessing": "openai/gpt-5.4-mini",
      "journeyEmbedding": "openai/text-embedding-3-small"
    }
  },
  "voice": {
    "provider": "openai",
    "apiKeyEnv": "OPENAI_API_KEY",
    "voice": "marin",
    "transcriptionLanguage": "de"
  },
  "discord": {
    "enabled": false,
    "botTokenEnv": "DISCORD_BOT_TOKEN",
    "applicationId": "000000000000000000",
    "guildId": "000000000000000000",
    "supportChannelId": "000000000000000000",
    "webAppUrl": "http://localhost:5173",
    "threadAutoArchiveDuration": 1440,
    "mirrorPollIntervalMs": 1000
  },
  "storage": {
    "sqlitePath": ".data/flight-demo.sqlite",
    "knowledgeIndexPath": ".data/knowledge-index.json"
  }
}
