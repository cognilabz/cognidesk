    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "streamdown": "^2.5.0",
