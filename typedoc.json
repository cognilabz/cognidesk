{
  "$schema": "https://typedoc.org/schema.json",
  "plugin": ["typedoc-plugin-markdown"],
  "entryPoints": [
    "packages/core/dist/index.d.ts",
    "packages/http/dist/index.d.ts",
    "packages/model/dist/index.d.ts",
    "packages/react/dist/index.d.ts",
    "packages/ui/dist/index.d.ts",
    "packages/storage/dist/index.d.ts",
    "packages/storage/dist/sqlite.d.ts",
    "packages/storage/dist/postgres.d.ts",
    "packages/storage/dist/conformance.d.ts",
    "packages/otel/dist/index.d.ts",
    "packages/integration-kit/dist/index.d.ts",
    "packages/integration-kit/dist/category-profiles.d.ts",
    "packages/integration-kit/dist/speech.d.ts",
    "packages/integration-kit/dist/testing/index.d.ts",
    "integrations/*/*/dist/index.d.ts",
    "integrations/*/*/dist/manifest.d.ts",
    "integrations/*/*/dist/runtime.d.ts",
    "packages/voice-websocket/dist/index.d.ts",
    "packages/journey-index-json/dist/index.d.ts",
    "packages/test-harness/dist/index.d.ts",
    "packages/test-harness/dist/providers.d.ts",
    "packages/studio-contracts/dist/index.d.ts"
  ],
  "out": "website/api-reference/generated",
  "outputFileStrategy": "modules",
  "readme": "none",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "useCodeBlocks": true,
  "expandObjects": true,
  "parametersFormat": "table",
  "enumMembersFormat": "table",
  "typeDeclarationFormat": "table",
  "skipErrorChecking": true,
  "disableSources": true
}
